<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Título centralizado (equivalente ao Center + Text no Flutter) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp">

        <TextView
            android:id="@+id/titleTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Galeria de Imagens"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@android:color/black" />
    </FrameLayout>

    <!-- Container que vai mudar dinamicamente: Row ou Column conforme orientação -->
    <LinearLayout
        android:id="@+id/imagesContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@android:drawable/dialog_holo_light_frame"
        android:padding="16dp">

        <!-- Três ImageViews (substitua os drawables pelos seus nomes) -->
        <ImageView
            android:id="@+id/image1"
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:layout_weight="1"
            android:layout_margin="8dp"
            android:src="@drawable/ic_launcher_foreground" <!-- imagem exemplo -->
            android:scaleType="centerCrop" />

        <ImageView
            android:id="@+id/image2"
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:layout_weight="1"
            android:layout_margin="8dp"
            android:src="@drawable/ic_launcher_foreground"
            android:scaleType="centerCrop" />

        <ImageView
            android:id="@+id/image3"
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:layout_weight="1"
            android:layout_margin="8dp"
            android:src="@drawable/ic_launcher_foreground"
            android:scaleType="centerCrop" />
    </LinearLayout>

    <!-- Rodapé com padding (equivalente ao Padding no Flutter) -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:background="#E0E0E0"
        android:text="Toque na imagem para detalhes"
        android:textAlignment="center"
        android:layout_marginTop="16dp" />

</LinearLayout>