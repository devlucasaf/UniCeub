<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Nome do produto -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nome do produto:"
            android:textStyle="bold"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/editProductName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ex: Hambúrguer artesanal"
            android:inputType="text"
            android:layout_marginTop="8dp" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="20dp" />

        <!-- Quantidade (Slider/SeekBar) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quantidade:"
            android:textStyle="bold"
            android:textSize="16sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <SeekBar
                android:id="@+id/seekBarQuantity"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="9"
                android:progress="0" />

            <TextView
                android:id="@+id/textQuantityValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1"
                android:paddingStart="16dp"
                android:textSize="16sp" />
        </LinearLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="20dp" />

        <!-- Tipo de entrega (RadioGroup) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tipo de entrega:"
            android:textStyle="bold"
            android:textSize="16sp" />

        <RadioGroup
            android:id="@+id/radioGroupDelivery"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">

            <RadioButton
                android:id="@+id/radioPickup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Retirar na loja" />

            <RadioButton
                android:id="@+id/radioDelivery"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Entregar no local" />

            <RadioButton
                android:id="@+id/radioMail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Correios" />
        </RadioGroup>

        <Space
            android:layout_width="match_parent"
            android:layout_height="20dp" />

        <!-- Região (Spinner) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Região:"
            android:textStyle="bold"
            android:textSize="16sp" />

        <Spinner
            android:id="@+id/spinnerRegion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="20dp" />

        <!-- Checkbox de promoções -->
        <CheckBox
            android:id="@+id/checkPromotions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Desejo receber promoções por e-mail" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="30dp" />

        <!-- Botão Cadastrar -->
        <Button
            android:id="@+id/buttonSubmit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Cadastrar"
            android:backgroundTint="@color/blue"
            android:textColor="@android:color/white" />

    </LinearLayout>
</ScrollView>