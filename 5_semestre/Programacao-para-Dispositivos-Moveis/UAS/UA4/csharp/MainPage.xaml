<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FormularioApp.Views.MainPage"
             Title="Menu Principal">
    
    <CollectionView SelectionMode="Single" SelectionChanged="OnMenuSelectionChanged">
        <CollectionView.ItemsSource>
            <x:Array Type="{x:Type x:String}">
                <x:String>Contador</x:String>
                <x:String>Cadastro de Pedido</x:String>
                <x:String>Exemplo de Widgets</x:String>
                <x:String>Cadastro de Usuário</x:String>
            </x:Array>
        </CollectionView.ItemsSource>
        
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Grid Padding="20" HeightRequest="60">
                    <Label Text="{Binding}" 
                           FontSize="18"
                           VerticalOptions="Center"/>
                </Grid>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>